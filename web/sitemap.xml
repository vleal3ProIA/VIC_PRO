<?xml version="1.0" encoding="UTF-8"?>
<!--
  sitemap.xml — lista de páginas indexables. El script
  `scripts/generate_seo.dart` regenera este archivo en build time
  sustituyendo `__SEO_SITE_URL__` por el dominio real y `__SEO_LASTMOD__`
  por la fecha de build.

  Solo páginas PÚBLICAS — las privadas están bloqueadas en robots.txt.
-->
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <url>
    <loc>__SEO_SITE_URL__/</loc>
    <lastmod>__SEO_LASTMOD__</lastmod>
    <changefreq>weekly</changefreq>
    <priority>1.0</priority>
  </url>
  <url>
    <loc>__SEO_SITE_URL__/welcome</loc>
    <lastmod>__SEO_LASTMOD__</lastmod>
    <changefreq>weekly</changefreq>
    <priority>0.9</priority>
  </url>
  <url>
    <loc>__SEO_SITE_URL__/login</loc>
    <lastmod>__SEO_LASTMOD__</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.5</priority>
  </url>
  <url>
    <loc>__SEO_SITE_URL__/register</loc>
    <lastmod>__SEO_LASTMOD__</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.5</priority>
  </url>
  <url>
    <loc>__SEO_SITE_URL__/status</loc>
    <lastmod>__SEO_LASTMOD__</lastmod>
    <changefreq>daily</changefreq>
    <priority>0.7</priority>
  </url>
  <url>
    <loc>__SEO_SITE_URL__/terms</loc>
    <lastmod>__SEO_LASTMOD__</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.3</priority>
  </url>
  <url>
    <loc>__SEO_SITE_URL__/privacy</loc>
    <lastmod>__SEO_LASTMOD__</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.3</priority>
  </url>
  <url>
    <loc>__SEO_SITE_URL__/cookies</loc>
    <lastmod>__SEO_LASTMOD__</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.3</priority>
  </url>
</urlset>
