# ============================================================================
# .env.example — plantilla para el archivo `.env` LOCAL del desarrollador.
# ----------------------------------------------------------------------------
# Copia a `.env` y rellena con valores reales. `.env` está gitignored.
# NUNCA commits credenciales reales en el repo.
#
# En CI/builds de staging/prod NO se usa este archivo. El pipeline pasa
# las variables vía `--dart-define=KEY=value` (o `--dart-define-from-file`)
# y el código las lee con prioridad sobre `.env`. Ver README → "Environments".
# ============================================================================

# ─────────────────────── App metadata ───────────────────────
APP_NAME=myapp
# APP_VERSION lo inyecta normalmente CI con el tag de git (--dart-define).
# En local lo puedes dejar vacío — Sentry usa "unknown" como release.
APP_VERSION=

# ─────────────────────── Supabase ───────────────────────
# Supabase Dashboard → Project Settings → API
#   - SUPABASE_URL          → "Project URL"
#   - SUPABASE_ANON_KEY     → "anon public" key (safe en cliente)
# NUNCA pongas aquí el `service_role` key — bypasea RLS y debe vivir solo
# en Edge Functions secrets.
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_ANON_KEY=<your-anon-public-key>

# ─────────────────────── Observability ───────────────────────
# Sentry DSN — Sentry → Settings → Projects → <tu-proyecto> → Client Keys.
# Vacío = Sentry desactivado (los errores siguen saliendo en consola via
# AppLogger). Útil en local para no contaminar el dashboard de Sentry.
SENTRY_DSN=

# ─────────────────────── Auth ───────────────────────
# Tamaño del OTP enviado por Supabase. Debe coincidir con:
# Supabase Dashboard → Authentication → Sign In/Up → Email OTP Length.
# Permitido: 4..10. Default Supabase: 6.
OTP_CODE_LENGTH=6

# ─────────────────────── Feature flags ───────────────────────
ENABLE_LOGGING=true
ENABLE_ANALYTICS=false
# Si true, fuerza logs JSON estructurados incluso en dev (útil para probar
# el formato sin desplegar).
STRUCTURED_LOGS=false

# ─────────────────────── SMTP (Edge Functions only) ───────────────────────
# Estas vars NO se leen desde Flutter — solo desde las Edge Functions
# del backend (send-email, auth-email-hook, stripe-webhook). Se configuran
# en Supabase Dashboard → Project Settings → Edge Functions → "Secrets".
# Aquí se documentan por referencia.
#
# Para Dondominio.com:
#   - SMTP_HOST=smtp.dondominio.com  (o el host que te indicaron)
#   - SMTP_PORT=465                  (SSL implícito)  o  587 (STARTTLS)
#   - SMTP_USER=no-reply@tudominio.com
#   - SMTP_PASSWORD=<password de la cuenta de email creada en panel>
#   - SMTP_FROM=no-reply@tudominio.com
#   - SMTP_FROM_NAME=myapp           (nombre comercial, vale leerlo del
#                                     branding pero por defecto va aquí)
#   - SMTP_USE_TLS=true              (true para 465, false para 587)
#
# Si SMTP_HOST no está configurado, sendEmail() devuelve 'failed' con
# error 'smtp_not_configured' — la app no rompe, solo no manda email.

# ─────────────────────── Auth Email Hook (Supabase) ───────────────────────
# Secret del Send Email Hook de Supabase. Se genera al activar el hook en
# Dashboard → Authentication → Hooks → Send email hook → Enable HTTPS.
# Pegar aquí el valor que muestre el dashboard:
#   AUTH_HOOK_SECRET=v1,whsec_xxxxxxxxxxxxxxxxxxxx

# ─────────────────────── Site URL (para emails) ───────────────────────
# URL pública del despliegue (sin slash final). Se usa para construir
# enlaces dentro de los emails (ej. "Ver facturas" → SITE_URL/billing/invoices).
# En local:    http://localhost:8080
# En staging:  https://staging.tudominio.com
# En prod:     https://tudominio.com
SITE_URL=http://localhost:8080
