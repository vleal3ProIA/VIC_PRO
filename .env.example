# Copy to .env (per environment) and fill in real values.
# .env is gitignored — never commit real credentials.

APP_NAME=myapp
APP_ENV=development

# Supabase
# Get these from: Supabase dashboard → Project Settings → API
# - SUPABASE_URL: "Project URL"
# - SUPABASE_ANON_KEY: "anon public" key (safe to ship in client)
# NEVER put the service_role key here — it bypasses RLS and must stay server-side.
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_ANON_KEY=<your-anon-public-key>

# Feature flags
ENABLE_LOGGING=true
ENABLE_ANALYTICS=false
